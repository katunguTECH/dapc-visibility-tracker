datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

generator client {
  provider = "prisma-client-js"
}

model Lead {
  id        String   @id @default(cuid())
  userId    String
  business  String
  email     String
  phone     String?
  whatsapp  String?
  quality   String?
  createdAt DateTime @default(now())
}