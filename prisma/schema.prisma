// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
}

// -----------------------------------------
// 1. BUSINESS LEADS
// Tracks businesses that have been audited
// -----------------------------------------
model Lead {
  id        String   @id @default(cuid())
  userId    String   // The Clerk User ID who generated the lead
  business  String   // Name of the audited business
  email     String
  phone     String?
  whatsapp  String?
  quality   String?  // 'High', 'Medium', 'Low' based on visibility gap
  createdAt DateTime @default(now())
}

// -----------------------------------------
// 2. M-PESA TRANSACTIONS
// Tracks every STK Push attempt and result
// -----------------------------------------
model Transaction {
  id                String    @id @default(cuid())
  userId            String    // Links to the Clerk User ID
  amount            Float
  phoneNumber       String    // The 2547... number used for payment
  
  // Safaricom Identifiers (Critical for Callbacks)
  checkoutRequestId String    @unique 
  merchantRequestId String
  
  // Status Tracking
  status            String    @default("PENDING") // PENDING, COMPLETED, FAILED
  mpesaReceipt      String?   @unique // The M-Pesa Code (e.g., RCK2L349JG)
  resultDesc        String?   // The human-readable response from Safaricom
  
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
}

// -----------------------------------------
// 3. SUBSCRIPTIONS
// Manages long-term access for subscribers
// -----------------------------------------
model Subscription {
  id            String    @id @default(cuid())
  userId        String    @unique // One subscription per Clerk User
  plan          String    @default("FREE") // FREE, PRO, ENTERPRISE
  status        String    @default("INACTIVE") // ACTIVE, INACTIVE, EXPIRED
  startDate     DateTime?
  endDate       DateTime?
  updatedAt     DateTime  @updatedAt
}